// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlserver"
}

// Enums are not supported natively by SQL Server connector in Prisma
// We use String and handle logic in application

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  role          String  @default("ATTENDANT")
  signature     String?   @db.NVarChar(Max)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignedConversations Conversation[] @relation("AssignedTo")
  departments           Department[]   @relation("UserDepartments")
}

model Department {
  id            String    @id @default(cuid())
  name          String    @unique
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  users         User[]         @relation("UserDepartments")
  conversations Conversation[]
  chatbotNodes  ChatbotNode[]  @relation("DepartmentRouting")
  whatsappInstances WhatsappInstance[] @relation("InstanceDepartments")
}

model Contact {
  id            String    @id @default(cuid())
  name          String?
  number        String    @unique
  email         String?   @db.NVarChar(255)
  profilePic    String?   @db.NVarChar(Max)
  notes         String?   @db.NVarChar(Max)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  conversations Conversation[]
}

model Conversation {
  id              String           @id @default(cuid())
  contactId       String
  status          String @default("BOT")
  assignedToId    String?
  departmentId    String?
  lastMessageAt   DateTime         @default(now())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  // Automation state
  currentFlowId   String?
  currentStepId   String?
  isBotActive     Boolean          @default(true)

  contact         Contact          @relation(fields: [contactId], references: [id])
  assignedTo      User?            @relation("AssignedTo", fields: [assignedToId], references: [id])
  department      Department?      @relation(fields: [departmentId], references: [id])
  messages        Message[]
}

model ChatbotFlow {
  id              String   @id @default(cuid())
  name            String
  description     String?
  isActive        Boolean  @default(true)
  isDefault       Boolean  @default(false)
  triggerKeywords String?  @db.NVarChar(Max) // Palavras-chave separadas por vírgula
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  nodes           ChatbotNode[]
  instances       WhatsappInstance[] @relation("FlowInstances")
}

model ChatbotNode {
  id          String         @id @default(cuid())
  flowId      String
  type        String       @default("MESSAGE")
  content     String  @db.NVarChar(Max)       // The text to send
  
  // Routing action
  routingDepartmentId String?

  flow        ChatbotFlow    @relation(fields: [flowId], references: [id], onDelete: Cascade)
  routingDepartment Department? @relation("DepartmentRouting", fields: [routingDepartmentId], references: [id])
  options     ChatbotOption[]
  
  // For linear flows without options
  nextStepId  String?
}

model ChatbotOption {
  id          String      @id @default(cuid())
  nodeId      String
  keyword     String      // e.g. "1", "Financeiro"
  label       String      // e.g. "Falar com financeiro"
  targetNodeId String     // ID of the node to go to
  
  node        ChatbotNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
}

// NodeType enum removed

model Message {
  id             String       @id @default(cuid())
  conversationId String
  body           String  @db.NVarChar(Max)
  fromMe         Boolean      @default(false)
  timestamp      DateTime     @default(now())
  type           String       @default("chat") // chat, image, video, etc.
  mediaUrl       String?   @db.NVarChar(Max)
  
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model SystemSettings {
  id        String   @id @default("global")
  isBotEnabled Boolean @default(true)
  updatedAt DateTime @updatedAt
}

model WhatsappInstance {
  id          String   @id @default(cuid())
  name        String   @unique
  instanceId  String   @unique
  status      String   @default("DISCONNECTED") // CONNECTED, DISCONNECTED, QRCODE
  number      String?
  integration String?  @default("WHATSAPP-BAILEYS") // WHATSAPP-BAILEYS, WHATSAPP-BUSINESS
  isActive    Boolean  @default(true)
  qrcode      String?   @db.NVarChar(Max)
  
  // Meta Cloud API Settings
  token       String?   @db.NVarChar(Max)
  phoneNumberId String?
  wabaId      String?
  
  departments Department[] @relation("InstanceDepartments")
  flows       ChatbotFlow[] @relation("FlowInstances")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
