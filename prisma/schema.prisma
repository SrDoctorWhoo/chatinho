// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  ATTENDANT
}

enum ConversationStatus {
  BOT
  QUEUED
  ACTIVE
  CLOSED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  role          UserRole  @default(ATTENDANT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignedConversations Conversation[] @relation("AssignedTo")
}

model Contact {
  id            String    @id @default(cuid())
  name          String?
  number        String    @unique
  profilePic    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  conversations Conversation[]
}

model Conversation {
  id              String           @id @default(cuid())
  contactId       String
  status          ConversationStatus @default(BOT)
  assignedToId    String?
  lastMessageAt   DateTime         @default(now())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  // Automation state
  currentFlowId   String?
  currentStepId   String?
  isBotActive     Boolean          @default(true)

  contact         Contact          @relation(fields: [contactId], references: [id])
  assignedTo      User?            @relation("AssignedTo", fields: [assignedToId], references: [id])
  messages        Message[]
}

model ChatbotFlow {
  id          String        @id @default(cuid())
  name        String
  description String?
  isActive    Boolean       @default(true)
  isDefault   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  nodes       ChatbotNode[]
}

model ChatbotNode {
  id          String         @id @default(cuid())
  flowId      String
  type        NodeType       @default(MESSAGE)
  content     String         // The text to send
  
  flow        ChatbotFlow    @relation(fields: [flowId], references: [id], onDelete: Cascade)
  options     ChatbotOption[]
  
  // For linear flows without options
  nextStepId  String?
}

model ChatbotOption {
  id          String      @id @default(cuid())
  nodeId      String
  keyword     String      // e.g. "1", "Financeiro"
  label       String      // e.g. "Falar com financeiro"
  targetNodeId String     // ID of the node to go to
  
  node        ChatbotNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
}

enum NodeType {
  MESSAGE
  QUESTION
  MENU
  TRANSFER
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  body           String       @db.Text
  fromMe         Boolean      @default(false)
  timestamp      DateTime     @default(now())
  type           String       @default("chat") // chat, image, video, etc.
  mediaUrl       String?
  
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model WhatsappInstance {
  id          String   @id @default(cuid())
  name        String   @unique
  instanceId  String   @unique
  status      String   @default("DISCONNECTED") // CONNECTED, DISCONNECTED, QRCODE
  qrcode      String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
